<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - FullCalendarMvcApp</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/app-shell.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/profile-menu.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/intervention-pages.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/FullCalendarMvcApp.styles.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="app-shell is-sidebar-collapsed @(ViewData["BodyClass"])" data-app-shell>
    <header class="app-header">
        <div class="app-header__brand">
            <a class="app-logo" asp-area="" asp-controller="Home" asp-action="Index" aria-label="Intervention Management Platform home">
                <span></span>
                <span></span>
                <span></span>
            </a>
            <div class="app-header__title">Intervention Management Platform</div>
        </div>
        <div class="app-header__actions">
            <partial name="_ProfileMenu" />
        </div>
    </header>

    <div class="app-layout">
        <partial name="_AppSidebar" />

        <div class="app-content">
            <div class="app-content__inner">
                <main role="main">
                    @RenderBody()
                </main>
            </div>
        </div>
    </div>

    <partial name="_DraftInterventionModal" />

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/app-shell.js" asp-append-version="true"></script>
    <script src="~/js/profile-menu.js" asp-append-version="true"></script>
    <script src="~/js/draft-intervention.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
