@{
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
}

<aside class="app-sidebar" aria-label="Application menu" data-app-sidebar>
    <button class="app-sidebar__toggle" type="button" aria-label="Expand menu" aria-expanded="false" data-sidebar-toggle>
        <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="M9 6l6 6-6 6" />
        </svg>
    </button>

    <nav class="app-sidebar__nav">
        <a class="app-sidebar__link @(currentAction == "Dashboard" || currentAction == "Index" ? "is-active" : "")" asp-area="" asp-controller="Home" asp-action="Dashboard" title="Dashboard">
            <svg viewBox="0 0 24 24" aria-hidden="true">
                <path d="M3 11.5L12 4l9 7.5" />
                <path d="M5 10.5V20h5v-5h4v5h5v-9.5" />
            </svg>
            <span>Dashboard</span>
        </a>

        <a class="app-sidebar__link @(currentAction == "PowerBI" ? "is-active" : "")" asp-area="" asp-controller="Home" asp-action="PowerBI" title="Power BI">
            <svg viewBox="0 0 24 24" aria-hidden="true">
                <path d="M5 19V9" />
                <path d="M10 19V5" />
                <path d="M15 19v-7" />
                <path d="M20 19V8" />
                <path d="M3 19h18" />
            </svg>
            <span>Power BI</span>
        </a>

        <a class="app-sidebar__link @(currentAction == "Calendar" ? "is-active" : "")" asp-area="" asp-controller="Home" asp-action="Calendar" title="Calendar">
            <svg viewBox="0 0 24 24" aria-hidden="true">
                <path d="M7 3v3" />
                <path d="M17 3v3" />
                <path d="M4 8h16" />
                <rect x="4" y="5" width="16" height="16" rx="2" />
            </svg>
            <span>Calendar</span>
        </a>

        <a class="app-sidebar__link @(currentAction == "CreateIntervention" ? "is-active" : "")" asp-area="" asp-controller="Home" asp-action="CreateIntervention" title="Create Intervention">
            <svg viewBox="0 0 24 24" aria-hidden="true">
                <circle cx="12" cy="12" r="9" />
                <path d="M12 8v8" />
                <path d="M8 12h8" />
            </svg>
            <span>Create Intervention</span>
        </a>

        <a class="app-sidebar__link" href="#" title="Draft Intervention" data-bs-toggle="modal" data-bs-target="#draftInterventionModal">
            <svg viewBox="0 0 24 24" aria-hidden="true">
                <path d="M8 4h8l3 3v13H5V4h3z" />
                <path d="M15 4v4h4" />
                <path d="M8 14h8" />
                <path d="M8 17h5" />
            </svg>
            <span>Draft Intervention</span>
        </a>

        <a class="app-sidebar__link @(currentAction == "Settings" ? "is-active" : "")" asp-area="" asp-controller="Home" asp-action="Settings" title="Settings">
            <svg viewBox="0 0 24 24" aria-hidden="true">
                <circle cx="12" cy="12" r="3" />
                <path d="M19.4 15a1.7 1.7 0 0 0 .3 1.8l.1.1-2.1 2.1-.1-.1a1.7 1.7 0 0 0-1.8-.3 1.7 1.7 0 0 0-1 1.5V20h-3v-.1a1.7 1.7 0 0 0-1-1.5 1.7 1.7 0 0 0-1.8.3l-.1.1-2.1-2.1.1-.1A1.7 1.7 0 0 0 6.6 15a1.7 1.7 0 0 0-1.5-1H5v-3h.1a1.7 1.7 0 0 0 1.5-1 1.7 1.7 0 0 0-.3-1.8l-.1-.1L8.3 6l.1.1a1.7 1.7 0 0 0 1.8.3 1.7 1.7 0 0 0 1-1.5V4h3v.9a1.7 1.7 0 0 0 1 1.5 1.7 1.7 0 0 0 1.8-.3l.1-.1 2.1 2.1-.1.1a1.7 1.7 0 0 0-.3 1.8 1.7 1.7 0 0 0 1.5 1h.7v3h-.7a1.7 1.7 0 0 0-1.5 1z" />
            </svg>
            <span>Settings</span>
        </a>
    </nav>

    <a class="app-sidebar__link app-sidebar__logout" href="#" title="Logout">
        <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="M10 17l5-5-5-5" />
            <path d="M15 12H3" />
            <path d="M21 4v16" />
        </svg>
        <span>Logout</span>
    </a>
</aside>
