@{
    ViewData["Title"] = "Settings";
    ViewData["BodyClass"] = "settings-page";
    var statuses = new[] { "Draft", "Proposed", "Scheduled", "Closed", "Cancelled", "Completed", "Conflict Check", "Await New Dates", "Started", "Change Request", "Confirmed", "Deferred", "Archive" };
}

<section class="page-shell" aria-labelledby="settingsTitle">
    <div class="page-heading">
        <div>
            <p class="eyebrow">Settings</p>
            <h1 id="settingsTitle">Application Settings</h1>
        </div>
    </div>

    <form class="data-panel settings-form" data-settings-form>
        <div class="panel-heading">
            <div>
                <h2>Email notification configuration</h2>
                <p>Select the intervention statuses that should trigger email notifications.</p>
            </div>
        </div>

        <label class="settings-master">
            <input id="settingsAllStatuses" class="form-check-input" type="checkbox" checked />
            <span>All</span>
        </label>

        <div class="settings-grid">
            @foreach (var status in statuses)
            {
                <label class="settings-option">
                    <input class="form-check-input" type="checkbox" name="notificationStatuses" value="@status" checked />
                    <span>@status</span>
                </label>
            }
        </div>

        <div class="form-actions">
            <span class="save-message" data-settings-message></span>
            <button type="submit" class="btn btn-primary">Save Settings</button>
        </div>
    </form>
</section>

@section Scripts {
    <script src="~/js/settings.js" asp-append-version="true"></script>
}
