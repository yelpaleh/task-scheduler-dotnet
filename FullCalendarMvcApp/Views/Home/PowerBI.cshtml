@{
    ViewData["Title"] = "Power BI";
    ViewData["BodyClass"] = "powerbi-page";
}

<section class="page-shell" aria-labelledby="powerBiTitle">
    <div class="page-heading">
        <div>
            <p class="eyebrow">Power BI</p>
            <h1 id="powerBiTitle">Intervention Status Report</h1>
        </div>
    </div>

    <section class="report-panel">
        <div class="panel-heading">
            <div>
                <h2>Status distribution</h2>
                <p>Single report chart based on intervention counts.</p>
            </div>
        </div>

        <div class="powerbi-visual" data-powerbi-chart>
            <div class="powerbi-bars" aria-label="Intervention status chart"></div>
            <div class="powerbi-summary">
                <strong id="powerBiTotal">0</strong>
                <span>Total interventions</span>
            </div>
        </div>
    </section>
</section>

@section Scripts {
    <script src="~/js/powerbi-report.js" asp-append-version="true"></script>
}
